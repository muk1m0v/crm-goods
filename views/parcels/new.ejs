<%- include('../partials/header') %>

<div class="card" style="max-width: 700px; margin: 0 auto;">
    <h2>Создание посылки</h2>
    <% if (error) { %>
        <div class="alert"><%= error %></div>
    <% } %>
    <form action="/parcels" method="POST">
        <div class="form-group">
            <label for="cargo_name">Название карго *</label>
            <input type="text" class="form-control" id="cargo_name" name="cargo_name" required>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label for="weight">Вес (кг) *</label>
                <input type="number" step="0.01" class="form-control" id="weight" name="weight" required>
            </div>
            <div class="form-group">
                <label for="cube">Куб (м³)</label>
                <input type="number" step="0.01" class="form-control" id="cube" name="cube">
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label for="username">Логин получателя *</label>
                <input type="text" class="form-control" id="username" name="username" required>
            </div>
            <div class="form-group">
                <label for="full_name">Полное имя *</label>
                <input type="text" class="form-control" id="full_name" name="full_name" required>
            </div>
        </div>
        <div class="form-group">
            <label for="phone">Телефон *</label>
            <input type="tel" class="form-control" id="phone" name="phone" required>
        </div>

        <div class="form-group">
            <label for="tracking_number">Трек-номер</label>
            <input type="text" class="form-control" id="tracking_number" name="tracking_number" placeholder="Например, TRK-2026-001">
        </div>
        <div class="form-group">
            <label for="status">Статус</label>
            <select class="form-control" id="status" name="status">
                <option value="принять на склад в китае">Принять на склад в Китае</option>
                <option value="в пути">В пути</option>
                <option value="в тамоденной проверке">В таможенной проверке</option>
                <option value="в сортировке">В сортировке</option>
                <option value="готов к получению">Готов к получению</option>
                <option value="получено">Получено</option>
            </select>
        </div>
        <div class="form-group">
            <label for="delivery_cost">Стоимость доставки ($)</label>
            <input type="number" step="0.01" class="form-control" id="delivery_cost" name="delivery_cost" placeholder="0.00">
        </div>
        <div class="form-group">
            <label for="paid">
                <input type="checkbox" id="paid" name="paid"> Оплачено
            </label>
        </div>

        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a href="/parcels" class="btn btn-outline-dark">Отмена</a>
    </form>
</div>

<%- include('../partials/footer') %>