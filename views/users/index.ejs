<%- include('../partials/header') %>

<h1>Пользователи</h1>

<div class="table-wrap card">
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Логин</th>
                <th>Полное имя</th>
                <th>Телефон</th>
                <th>Роль</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            <% users.forEach(u => { %>
            <tr>
                <td><%= u.id %></td>
                <td><%= u.username %></td>
                <td><%= u.full_name %></td>
                <td><%= u.phone || '—' %></td>
                <td><%= u.role %></td>
                <td class="actions">
                    <a href="/users/<%= u.id %>/edit" class="btn btn-sm btn-outline-dark">Редактировать</a>
                    <form action="/users/<%= u.id %>/delete" method="POST" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Удалить пользователя?')">Удалить</button>
                    </form>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<%- include('../partials/footer') %>